APP_PORT=3000
APP_BACKEND=local
APP_URL=https://cleaning.example.com
APP_TIMEZONE=Europe/Warsaw
SETUP_USERNAME=admin
SETUP_PASSWORD=change-this-before-production

# Use a long random value. The scheduler service and app must use the same value.
CRON_SECRET=replace-with-long-random-secret

# Optional, only needed for real email sending.
RESEND_API_KEY=
EMAIL_FROM=Cleaning Duty <noreply@example.com>

# Optional, only if switching backend mode to Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
